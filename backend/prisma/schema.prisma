generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  
  // Это поле мы будем использовать для публичного ключа шифрования
  publicKey    String?  

  // Твои текущие поля профиля
  gender       String
  age          Int
  location     String
  bio          String?
  createdAt    DateTime @default(now())

  // Связь: сообщения, которые лежат на сервере и ждут этого пользователя
  receivedMessages Message[] @relation("ReceiverRelation")
  sentMessages     Message[] @relation("SenderRelation")
}

model Message {
  id          String   @id @default(uuid())
  content     String   // Зашифрованный текст или обычный (пока настраиваем)
  senderId    String
  receiverId  String
  createdAt   DateTime @default(now())

  // Отношения (чтобы Prisma понимала, кто кому пишет)
  sender      User     @relation("SenderRelation", fields: [senderId], references: [id])
  receiver    User     @relation("ReceiverRelation", fields: [receiverId], references: [id])
}