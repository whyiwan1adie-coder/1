generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Location {
  не_указано
  россия
  европа
  азия
  америка
  африка
  океания
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String
  accessKeyHash String?
  publicKey     String?
  avatar        String?
  nickname      String?
  bio           String?
  gender        String   @default("не указан")
  age           Int      @default(0)
  location      Location @default(не_указано)
  languages     String   @default("")
  status        String   @default("offline")
  createdAt     DateTime @default(now())

  receivedMessages Message[] @relation("ReceiverRelation")
  sentMessages     Message[] @relation("SenderRelation")
  sentRequests     Friendship[] @relation("FromUserRelation")
  receivedRequests Friendship[] @relation("ToUserRelation")
  wallPosts        WallPost[]
}

model Message {
  id          String   @id @default(uuid())
  content     String   
  senderId    String
  receiverId  String
  createdAt   DateTime @default(now())

  sender      User     @relation("SenderRelation", fields: [senderId], references: [id])
  receiver    User     @relation("ReceiverRelation", fields: [receiverId], references: [id])
}

model Friendship {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  fromUser   User     @relation("FromUserRelation", fields: [fromUserId], references: [id])
  toUser     User     @relation("ToUserRelation", fields: [toUserId], references: [id])
}

model WallPost {
  id        String   @id @default(uuid())
  text      String
  image     String?
  audio     String?
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id])
}